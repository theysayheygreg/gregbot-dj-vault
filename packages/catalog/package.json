{
  "name": "@dj-vault/catalog",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "init": "node dist/cli/init-catalog.js",
    "ingest:files": "node dist/cli/ingest-files.js",
    "create:playlist": "node dist/cli/create-playlist.js",
    "create:set": "node dist/cli/create-set.js",
    "add:track-to-playlist": "node dist/cli/add-track-to-playlist.js",
    "add:track-to-set": "node dist/cli/add-track-to-set.js",
    "create:playback-session": "node dist/cli/create-playback-session.js",
    "log:playback-event": "node dist/cli/log-playback-event.js",
    "recency:report": "node dist/cli/recency-report.js",
    "import:playback-history": "node dist/cli/import-playback-history.js",
    "import:rekordbox-collection": "node dist/cli/import-rekordbox-collection.js",
    "import:rekordbox-history": "node dist/cli/import-rekordbox-history.js",
    "import:rekordbox-library": "node dist/cli/import-rekordbox-library.js",
    "import:traktor-collection": "node dist/cli/import-traktor-collection.js",
    "import:traktor-history": "node dist/cli/import-traktor-history.js",
    "import:traktor-library": "node dist/cli/import-traktor-library.js",
    "register:node": "node dist/cli/register-node.js",
    "register:storage": "node dist/cli/register-storage.js",
    "record:track-residency": "node dist/cli/record-track-residency.js",
    "plan:export-execution": "node dist/cli/plan-export-execution.js",
    "export:rekordbox-xml": "node dist/cli/export-rekordbox-xml.js",
    "export:traktor-nml": "node dist/cli/export-traktor-nml.js",
    "qmd:export": "node dist/cli/qmd-export.js",
    "qmd:setup": "node dist/cli/qmd-setup.js",
    "qmd:update": "node dist/cli/qmd-update.js",
    "qmd:embed": "node dist/cli/qmd-embed.js",
    "qmd:status": "node dist/cli/qmd-status.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
