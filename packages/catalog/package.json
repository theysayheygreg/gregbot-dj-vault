{
  "name": "@dj-vault/catalog",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "init": "node dist/cli/init-catalog.js",
    "ingest:files": "node dist/cli/ingest-files.js",
    "qmd:export": "node dist/cli/qmd-export.js",
    "qmd:setup": "node dist/cli/qmd-setup.js",
    "qmd:update": "node dist/cli/qmd-update.js",
    "qmd:embed": "node dist/cli/qmd-embed.js",
    "qmd:status": "node dist/cli/qmd-status.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2"
  }
}
